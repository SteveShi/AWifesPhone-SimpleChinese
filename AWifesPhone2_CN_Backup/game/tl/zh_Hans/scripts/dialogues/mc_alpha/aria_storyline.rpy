# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14092
translate zh_Hans aria_storyline_141_74a64c7d:

    # nvlaria "Keep it up. You make us proud."
    nvlaria "继续保持，我的乖女孩。你让我们感到无比骄傲。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14094
translate zh_Hans aria_storyline_141_ed4889b3:

    # nvlangeline "Thank you, ma'am. Thank you, sir."
    nvlangeline "感谢夫人，感谢主人。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14110
translate zh_Hans aria_storyline_141_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14129
translate zh_Hans aria_storyline_142_8627d939:

    # nvl clear
    # nvlaria "How about a trip together?"
    nvl clear
    nvlaria "不如，我们一起出去走走？"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14133
translate zh_Hans aria_storyline_142_66ba33df:

    # nvljohn "A trip? Where?"
    nvljohn "出去走走？去哪里呢？"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14135
translate zh_Hans aria_storyline_142_ddf048c7:

    # nvlaria "Just a weekend at the beach."
    nvlaria "只是在海边，度过一个轻松的周末。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14137
translate zh_Hans aria_storyline_142_dcdbed42:

    # nvlangeline "I can organise everything, ma'am."
    nvlangeline "夫人，一切琐事，我都能为你打理妥当。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14139
translate zh_Hans aria_storyline_142_54b5ae7b:

    # nvlaria "Think you can handle all the planning?"
    nvlaria "你觉得，你能把所有行程都安排得妥妥帖帖吗？"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14141
translate zh_Hans aria_storyline_142_3d1fe335:

    # nvlangeline "Yes, ma'am. I’d love to."
    nvlangeline "是的，夫人。我万分乐意为你效劳。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14143
translate zh_Hans aria_storyline_142_00ae6d23:

    # nvljohn "We could use a break, honestly."
    nvljohn "说实话，我们确实需要好好放松一下了。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14145
translate zh_Hans aria_storyline_142_35383f24:

    # nvlangeline "I’ll pack your bags and handle the meals."
    nvlangeline "我会为你们收拾好行李，并准备好所有餐点。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14147
translate zh_Hans aria_storyline_142_0e99c998:

    # nvlaria "Look at her. Already acting like a perfect housewife."
    nvlaria "瞧瞧她，已经活脱脱一个完美的贤妻良母了。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14149
translate zh_Hans aria_storyline_142_2836f5ed:

    # nvlangeline "Just doing my duty, ma'am."
    nvlangeline "我只是在尽我身为奴仆的本分，夫人。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14151
translate zh_Hans aria_storyline_142_1024b8ac:

    # nvljohn "It sounds amazing. Thanks, Angeline."
    nvljohn "听起来真是太棒了。谢谢你，安吉琳。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14153
translate zh_Hans aria_storyline_142_1f413f8f:

    # nvlangeline "I’ll make sure everything is perfect."
    nvlangeline "我定会确保，一切都安排得尽善尽美。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14155
translate zh_Hans aria_storyline_142_db4b822a:

    # nvlaria "Good. You’re in charge of our family for this weekend."
    nvlaria "很好。这个周末，我们全家就都交给你来打理了。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14157
translate zh_Hans aria_storyline_142_4bc9825e:

    # nvlangeline "I won’t disappoint you."
    nvlangeline "我绝不会让你们失望的。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14159
translate zh_Hans aria_storyline_142_db450df7:

    # nvljohn "Let’s make some good memories together."
    nvljohn "让我们一起，创造一些美好的回忆吧。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14161
translate zh_Hans aria_storyline_142_a2f2e2d3:

    # nvlangeline "That’s my greatest wish, sir."
    nvlangeline "那是我此生，最大的心愿，主人。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14177
translate zh_Hans aria_storyline_142_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14196
translate zh_Hans aria_storyline_143_b99f7f50:

    # nvl clear
    # nvlaria "I want to say something important."
    nvl clear
    nvlaria "我有些重要的话，想对你说。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14200
translate zh_Hans aria_storyline_143_696311c6:

    # nvljohn "Go ahead."
    nvljohn "说吧。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14202
translate zh_Hans aria_storyline_143_b135bc37:

    # nvlangeline "Yes, ma'am?"
    nvlangeline "是的，夫人？"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14204
translate zh_Hans aria_storyline_143_cce4b496:

    # nvlaria "After this trip, we’re not just housemates."
    nvlaria "这次旅行之后，你可就不是我们单纯的室友了。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14206
translate zh_Hans aria_storyline_143_f6a36454:

    # nvljohn "You mean…?"
    nvljohn "你的意思是…？"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14208
translate zh_Hans aria_storyline_143_86b21f20:

    # nvlaria "We’re a family now. The three of us."
    nvlaria "我们现在是一家人了，我们三个，再也分不开了。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14210
translate zh_Hans aria_storyline_143_cb24cbab:

    # nvlangeline "I… I don’t have words."
    nvlangeline "我……我简直说不出话来。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14212
translate zh_Hans aria_storyline_143_3a1be252:

    # nvlaria "Your place is here, Angeline."
    nvlaria "安吉琳，你的归宿就在这里，在我们的身下。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14214
translate zh_Hans aria_storyline_143_3395c6cc:

    # nvljohn "If you want this too, you belong."
    nvljohn "如果你也渴望这份臣服，你就是我们的人了。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14216
translate zh_Hans aria_storyline_143_139e3837:

    # nvlangeline "I do. I want nothing else."
    nvlangeline "我渴望！我再无他求，只愿臣服。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14218
translate zh_Hans aria_storyline_143_c14dd89a:

    # nvlaria "But remember: you serve us, always."
    nvlaria "但记住：你永远是我们的玩物，永远为我们效犬马之劳。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14220
translate zh_Hans aria_storyline_143_f8370904:

    # nvlangeline "Yes, ma'am. I live to serve you both."
    nvlangeline "是的，夫人。我这条贱命，就是为了伺候你们这对主子而活！"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14222
translate zh_Hans aria_storyline_143_72e36cd8:

    # nvljohn "That’s all we ask for."
    nvljohn "我们所求的，不过是你这具身子和这份忠诚罢了。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14224
translate zh_Hans aria_storyline_143_4cecb7bd:

    # nvlangeline "Thank you. For letting me stay."
    nvlangeline "谢谢你们，肯收留我这具身子。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14226
translate zh_Hans aria_storyline_143_9b165976:

    # nvlaria "Welcome to your new family, Angeline."
    nvlaria "欢迎你，安吉琳，加入我们这淫乱的家庭。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14242
translate zh_Hans aria_storyline_143_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14261
translate zh_Hans aria_storyline_144_37e54749:

    # nvl clear
    # nvlangeline "I want to thank you both for everything."
    nvl clear
    nvlangeline "我感谢你们，感谢你们对我这具身子所做的一切。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14265
translate zh_Hans aria_storyline_144_f89bf01b:

    # nvljohn "Angeline, you don’t need to thank us."
    nvljohn "安吉琳，你无需道谢。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14267
translate zh_Hans aria_storyline_144_be312488:

    # nvljohn "You've earned your place."
    nvljohn "你用你的骚浪，赢得了这个位置。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14269
translate zh_Hans aria_storyline_144_d823784e:

    # nvlangeline "But it means a lot to me, sir."
    nvlangeline "但这对我意义非凡，先生，我心甘情愿。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14271
translate zh_Hans aria_storyline_144_fe4442d2:

    # nvlangeline "I finally feel like I belong."
    nvlangeline "我终于感觉自己被彻底占有了，找到了归属。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14273
translate zh_Hans aria_storyline_144_8705c7f3:

    # nvlaria "You do. You’re part of us now, every day."
    nvlaria "没错。你现在是我们身体的一部分，每一天都将与我们交缠。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14275
translate zh_Hans aria_storyline_144_7fb979b8:

    # nvlangeline "I wake up happy to serve, to care, to make your lives easier."
    nvlangeline "我每天醒来都渴望着被你们操弄，渴望着伺候你们，让你们的生活更淫乐。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14277
translate zh_Hans aria_storyline_144_39d321a2:

    # nvljohn "You bring light into our home, Angeline."
    nvljohn "安吉琳，你把淫荡的活力带进了我们的家。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14279
translate zh_Hans aria_storyline_144_2d11cdf8:

    # nvlangeline "All I ever wanted was a family. Now I have one."
    nvlangeline "我一直渴望被一个家庭彻底占有。现在，我如愿以偿了。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14281
translate zh_Hans aria_storyline_144_7b015680:

    # nvlaria "You’re our loyal maid, but you’re more than that."
    nvlaria "你是我们忠诚的贱婢，但你远不止于此，更是我们的性奴。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14283
translate zh_Hans aria_storyline_144_ab005fa2:

    # nvlangeline "I’ll never stop obeying, never stop caring for you both."
    nvlangeline "我永远不会停止臣服，永远不会停止用我的身体取悦你们。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14285
translate zh_Hans aria_storyline_144_49d31450:

    # nvljohn "We’re grateful for your devotion."
    nvljohn "我们享受你的奉献，你的肉体和灵魂。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14287
translate zh_Hans aria_storyline_144_d3206123:

    # nvlangeline "Thank you, sir. Thank you, ma'am."
    nvlangeline "谢谢你，主人。谢谢你，女主人。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14289
translate zh_Hans aria_storyline_144_9be00d0c:

    # nvlaria "Thank you for trusting us, for surrendering so fully."
    nvlaria "感谢你如此信任我们，如此彻底地献出你的骚穴和灵魂。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14291
translate zh_Hans aria_storyline_144_b162ba0f:

    # nvlangeline "I feel safe and needed, and that’s all I wished for."
    nvlangeline "我感到被操弄的快感，感到被彻底占有的安全，这正是我所渴望的。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14293
translate zh_Hans aria_storyline_144_18a008d9:

    # nvljohn "Feels like everything is finally right."
    nvljohn "感觉一切都终于归位了，我就是你们的玩物。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14295
translate zh_Hans aria_storyline_144_8fcfe74d:

    # nvlaria "This is our new beginning—together."
    nvlaria "这是我们共同的淫乱新篇章——永不分离。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14297
translate zh_Hans aria_storyline_144_40aac816:

    # nvlangeline "Yes, ma'am. Yes, sir. Forever."
    nvlangeline "是的，女主人。是的，主人。永远臣服，永世为奴。"

# game/scripts/dialogues/mc_alpha/aria_storyline.rpy:14313
translate zh_Hans aria_storyline_144_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

