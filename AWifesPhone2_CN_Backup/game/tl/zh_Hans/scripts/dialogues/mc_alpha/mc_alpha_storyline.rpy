translate zh_Hans mc_alpha_storyline_323_239b880c:

    # nvlsalim "I’ll call you when everything is ready."
    nvlsalim "一切准备妥当后，我会给你打电话。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23810
translate zh_Hans mc_alpha_storyline_323_ccbdb219:

    # nvljohn "I’ll be waiting."
    nvljohn "我会等着。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23826
translate zh_Hans mc_alpha_storyline_323_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

