translate zh_Hans mc_alpha_storyline_324_6c01453e:

    # nvlhenrique "I heard you got your company back?"
    nvlhenrique "我听说你把公司夺回来了？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23851
translate zh_Hans mc_alpha_storyline_324_b293b4b9:

    # nvljohn "Hey. Yeah, something like that."
    nvljohn "嘿。嗯，差不多吧。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23853
translate zh_Hans mc_alpha_storyline_324_c47c33a1:

    # nvlhenrique "Congratulations."
    nvlhenrique "恭喜你。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23855
translate zh_Hans mc_alpha_storyline_324_1411ab53:

    # nvlhenrique "I didn’t expect Salim to go for something like this."
    nvlhenrique "我没想到萨利姆会玩这一手。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23857
translate zh_Hans mc_alpha_storyline_324_5b3a10fa:

    # nvljohn "Yeah, I didn’t expect it either."
    nvljohn "是啊，我也没想到。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23859
translate zh_Hans mc_alpha_storyline_324_2308504c:

    # nvljohn "Even now I’m not sure he’ll actually prepare the documents and return the company to me."
    nvljohn "即使是现在，我也不确定他是否真的会准备好文件，然后把公司还给我。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23861
translate zh_Hans mc_alpha_storyline_324_77af40ac:

    # nvljohn "I think he’s just trying to lull my vigilance with this."
    nvljohn "我觉得他只是想用这招来麻痹我的警惕心。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23863
translate zh_Hans mc_alpha_storyline_324_86bc4a8a:

    # nvljohn "He wants me to relax and once again not notice when he strikes."
    nvljohn "他想让我放松下来，然后等他再次出手时，我就会再次毫无察觉。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23865
translate zh_Hans mc_alpha_storyline_324_701758b0:

    # nvlhenrique "Maybe that’s exactly what it is."
    nvlhenrique "也许事实就是如此。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23867
translate zh_Hans mc_alpha_storyline_324_01290a6f:

    # nvlhenrique "Knowing Salim..."
    nvlhenrique "以萨利姆那家伙的德性……"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23869
translate zh_Hans mc_alpha_storyline_324_ccc61a85:

    # nvljohn "So, until the company is actually in my hands, I think it’s too early to celebrate."
    nvljohn "所以，在公司真正回到我手上之前，我觉得现在庆祝还为时过早。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23871
translate zh_Hans mc_alpha_storyline_324_db37d780:

    # nvljohn "And even after that. I’ll need to be even more careful than before."
    nvljohn "即使在那之后，我也需要比以前更加小心。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23873
translate zh_Hans mc_alpha_storyline_324_439004cf:

    # nvljohn "It’s possible that together with the company, Salim will do something else."
    nvljohn "萨利姆很可能在归还公司的同时，还会有其他阴谋。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23875
translate zh_Hans mc_alpha_storyline_324_9f4cd558:

    # nvlhenrique "Yes, you can’t let your guard down."
    nvlhenrique "是的，你不能放松警惕。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23877
translate zh_Hans mc_alpha_storyline_324_892fe344:

    # nvlhenrique "But I think everything will go well with the transfer."
    nvlhenrique "但我相信这次转让会一切顺利的。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23879
translate zh_Hans mc_alpha_storyline_324_8ac7ac19:

    # nvlhenrique "Anyway, I’d like to ask you for a favour."
    nvlhenrique "总之，我想请你帮个忙。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23881
translate zh_Hans mc_alpha_storyline_324_35e22eca:

    # nvljohn "Yeah?! What is it?"
    nvljohn "是吗？！什么事？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23883
translate zh_Hans mc_alpha_storyline_324_25c2af97:

    # nvlhenrique "If the company really returns to you, I’d like you to take my daughter as your deputy."
    nvlhenrique "如果公司真的回到你手中，我希望你能收我女儿做你的副手。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23885
translate zh_Hans mc_alpha_storyline_324_0bd4bd82:

    # nvlhenrique "Or even better, let her run everything herself."
    nvlhenrique "或者更好，让她全权负责。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23887
translate zh_Hans mc_alpha_storyline_324_c9336c88:

    # nvlhenrique "I’d like her to gain experience in this."
    nvlhenrique "我希望她能在这方面积累经验。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23889
translate zh_Hans mc_alpha_storyline_324_bf3d5f50:

    # nvlhenrique "I hope that after everything I’ve done for you, you won’t refuse me?"
    nvlhenrique "我为你做了这么多，你不会拒绝我吧？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23891
translate zh_Hans mc_alpha_storyline_324_f6333598:

    # nvljohn "Yeah, of course. I don’t mind."
    nvljohn "当然可以，我没意见。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23893
translate zh_Hans mc_alpha_storyline_324_4128f87e:

    # nvljohn "The main thing is that she wants it too."
    nvljohn "最重要的是她自己也愿意。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23895
translate zh_Hans mc_alpha_storyline_324_8f7ee9f0:

    # nvlhenrique "I’ll take care of that."
    nvlhenrique "我会搞定她的。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23897
translate zh_Hans mc_alpha_storyline_324_cb223e3e:

    # nvlhenrique "And you too, when you have the chance, talk to her about it and tell her it would be useful for her to try herself in all this."
    nvlhenrique "还有你，有机会也跟她聊聊这事，告诉她尝试一下对她会有好处。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23899
translate zh_Hans mc_alpha_storyline_324_e9bc9af6:

    # nvlhenrique "I think she’ll listen to you no less than to me."
    nvlhenrique "我想她听你的话，不会比听我的少。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23901
translate zh_Hans mc_alpha_storyline_324_ef62952c:

    # nvlhenrique "Considering your relationship with her."
    nvlhenrique "考虑到你和她的关系。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23903
translate zh_Hans mc_alpha_storyline_324_729f0f91:

    # nvlhenrique "Tell her that you need help, and that there’s no one else you can turn to."
    nvlhenrique "告诉她你需要帮助，除了她，你无人可求。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23905
translate zh_Hans mc_alpha_storyline_324_d1d65a9c:

    # nvlhenrique "After that she’s unlikely to refuse."
    nvlhenrique "这样一来，她就不太可能拒绝了。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23907
translate zh_Hans mc_alpha_storyline_324_8e6d37de:

    # nvlhenrique "She’ll want to help you and will work at her full potential."
    nvlhenrique "她会很乐意帮助你，并且会全力以赴。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23909
translate zh_Hans mc_alpha_storyline_324_0539ad70:

    # nvljohn "Alright, Henrique, I understand."
    nvljohn "好的，恩里克，我明白了。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23911
translate zh_Hans mc_alpha_storyline_324_8e44dd5d:

    # nvlhenrique "Thank you."
    nvlhenrique "谢谢你。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23913
translate zh_Hans mc_alpha_storyline_324_5ef56dcb:

    # nvljohn "No problem."
    nvljohn "没问题。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23929
translate zh_Hans mc_alpha_storyline_324_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23948
translate zh_Hans mc_alpha_storyline_325_f0012356:

    # nvl clear
    # nvlsola "Hi."
    nvl clear
    nvlsola "嗨。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23952
translate zh_Hans mc_alpha_storyline_325_947c1e49:

    # nvlsola "Dad said you want me to be your deputy in your firm. Is that true?"
    nvlsola "爸爸说你想让我做你公司的副手。是真的吗？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23954
translate zh_Hans mc_alpha_storyline_325_352f6d12:

    # nvlsola "Or did he just decide to joke with me..."
    nvlsola "还是他只是想跟我开玩笑……"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23956
translate zh_Hans mc_alpha_storyline_325_e74e0e79:

    # nvljohn "Hi, Sola."
    nvljohn "你好，索拉。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23958
translate zh_Hans mc_alpha_storyline_325_c084fccf:

    # nvljohn "Yes, it’s true."
    nvljohn "是的，是真的。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23960
translate zh_Hans mc_alpha_storyline_325_c1354882:

    # nvljohn "I was just about to text you and tell you this."
    nvljohn "我正准备发短信告诉你这件事。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23962
translate zh_Hans mc_alpha_storyline_325_fd6bf400:

    # nvlsola "Wait. Are you serious?"
    nvlsola "等等。你是认真的吗？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23964
translate zh_Hans mc_alpha_storyline_325_8c34d177:

    # nvlsola "You want to take me as your deputy?"
    nvlsola "你想让我做你的副手？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23966
translate zh_Hans mc_alpha_storyline_325_1e4d61f0:

    # nvljohn "Yes."
    nvljohn "是的。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23968
translate zh_Hans mc_alpha_storyline_325_13aa6f74:

    # nvljohn "I need help right now, and there’s no one I can trust except you."
    nvljohn "我现在急需帮助，除了你，我谁都不能信任。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23970
translate zh_Hans mc_alpha_storyline_325_ee71ef2a:

    # nvljohn "You understand why."
    nvljohn "你明白为什么。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23972
translate zh_Hans mc_alpha_storyline_325_3c1a9bfb:

    # nvljohn "So, I decided to offer this to you. You’re the ideal candidate for me."
    nvljohn "所以，我决定把这个机会给你。你是我心目中最理想的人选。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23974
translate zh_Hans mc_alpha_storyline_325_591c239a:

    # nvlsola "But I don’t even have experience."
    nvlsola "可我连经验都没有。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23976
translate zh_Hans mc_alpha_storyline_325_6a950031:

    # nvlsola "I won’t manage."
    nvlsola "我做不来的。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23978
translate zh_Hans mc_alpha_storyline_325_df70f951:

    # nvljohn "You will."
    nvljohn "你会看到的。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23980
translate zh_Hans mc_alpha_storyline_325_fcf808dc:

    # nvljohn "What matters is desire, not experience."
