    # nvl clear
    # nvlsalim "So, what have you decided?"
    nvl clear
    nvlsalim "那么，你决定好了吗？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23766
translate zh_Hans mc_alpha_storyline_323_60fb746e:

    # nvljohn "I told you everything at the meeting."
    nvljohn "我在会议上把所有事情都告诉你了。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23768
translate zh_Hans mc_alpha_storyline_323_adb825ec:

    # nvljohn "My opinion of you can’t change in a couple of days."
    nvljohn "我对你的看法不可能在短短几天内改变。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23770
translate zh_Hans mc_alpha_storyline_323_c450bacf:

    # nvljohn "And I can’t trust you after everything that happened."
    nvljohn "经历了这一切之后，我无法再信任你了。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23772
translate zh_Hans mc_alpha_storyline_323_ce8f5270:

    # nvljohn "And believing words..."
    nvljohn "以及相信那些话语……"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23774
translate zh_Hans mc_alpha_storyline_323_ed4b41b7:

    # nvljohn "That’s a luxury for me, after my whole life nearly collapsed right before my eyes."
    nvljohn "对我来说，那是一种奢侈，因为我的整个生活几乎就在我眼前崩塌了。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23776
translate zh_Hans mc_alpha_storyline_323_e7093ced:

    # nvljohn "Besides, I don’t believe you’re capable of simply forgetting everything and disappearing."
    nvljohn "此外，我不相信你能够忘记一切然后消失。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23778
translate zh_Hans mc_alpha_storyline_323_aec207b0:

    # nvljohn "You’re not that kind of man."
    nvljohn "你不是那种人。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23780
translate zh_Hans mc_alpha_storyline_323_e7a5e6f8:

    # nvlsalim "I understand you."
    nvlsalim "我理解你。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23782
translate zh_Hans mc_alpha_storyline_323_4cafa606:

    # nvlsalim "If I were in your place, I couldn’t trust someone like me either."
    nvlsalim "如果我是你，我也无法信任像我这样的人。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23784
translate zh_Hans mc_alpha_storyline_323_6591297f:

    # nvlsalim "But I’m serious about fixing things between us."
    nvlsalim "但我是真心想修复我们之间的关系。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23786
translate zh_Hans mc_alpha_storyline_323_3c96d687:

    # nvlsalim "Therefore, I’ve initiated the process of returning the rights to the company that originally belonged to you."
    nvlsalim "因此，我已经启动了将原本属于你的版权归还给公司的程序。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23788
translate zh_Hans mc_alpha_storyline_323_00851fb7:

    # nvlsalim "Let that be the first step toward us beginning to at least slightly trust each other."
    nvlsalim "就让这成为我们开始至少略微信任彼此的第一步吧。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23790
translate zh_Hans mc_alpha_storyline_323_db143f41:

    # nvljohn "And what’s the catch?"
    nvljohn "那其中有什么猫腻呢？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23792
translate zh_Hans mc_alpha_storyline_323_64c77dc5:

    # nvlsalim "There is none."
    nvlsalim "没有。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23794
translate zh_Hans mc_alpha_storyline_323_92acebb4:

    # nvlsalim "Next week we can meet and formalise everything properly."
    nvlsalim "下周我们可以见面，正式确定所有细节。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23796
translate zh_Hans mc_alpha_storyline_323_c2d65aca:

    # nvlsalim "I’ll prepare the documents."
    nvlsalim "我会把文件准备好。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23798
translate zh_Hans mc_alpha_storyline_323_316b1922:

    # nvljohn "Do you need anything from me?"
    nvljohn "你需要我做什么吗？"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23800
translate zh_Hans mc_alpha_storyline_323_18321a08:

    # nvlsalim "No, nothing."
    nvlsalim "不，什么都没说。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23802
translate zh_Hans mc_alpha_storyline_323_3fd1a819:

    # nvlsalim "Just come to my office next week so we can finalise the deal."
    nvlsalim "下周来我办公室一趟，我们就能把这笔交易彻底敲定了。"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23804
translate zh_Hans mc_alpha_storyline_323_1a11e3f5:

    # nvljohn "Okay..."
    nvljohn "好的……"

# game/scripts/dialogues/mc_alpha/mc_alpha_storyline.rpy:23806
translate zh_Hans mc_alpha_storyline_323_92f4875d:

    # nvlsalim "Have a good day, Mr [mc_name_is]."
    nvlsalim "祝你今天愉快，[mc_name_is]先生。"

