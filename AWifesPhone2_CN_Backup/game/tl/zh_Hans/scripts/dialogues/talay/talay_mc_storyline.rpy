    nvljohn "一个无人知晓我们过往的地方，只有你和我。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10245
translate zh_Hans talay_mc_storyline_116_ff1ca91e:

    # nvltalay "I miss the feeling of sand under my feet."
    nvltalay "我想念脚趾深陷沙砾，被海浪轻抚的酥麻感。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10247
translate zh_Hans talay_mc_storyline_116_5988dc69:

    # nvljohn "We could get a small house by the beach."
    nvljohn "我们可以在海边筑一个爱巢，只属于我们。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10249
translate zh_Hans talay_mc_storyline_116_5f04f3ab:

    # nvljohn "Long walks, lazy afternoons, your head on my chest."
    nvljohn "漫长的海边漫步，慵懒的午后，你的头枕在我胸口，感受我的心跳。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10251
translate zh_Hans talay_mc_storyline_116_4b9f80c7:

    # nvltalay "A hammock… coconut water…"
    nvltalay "吊床……冰凉的椰汁……还有你湿润的唇。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10253
translate zh_Hans talay_mc_storyline_116_3f6d9f86:

    # nvltalay "And you, always close."
    nvltalay "还有你，永远紧紧贴着我，不曾分离。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10255
translate zh_Hans talay_mc_storyline_116_3fac9a50:

    # nvljohn "We’ll make it happen one day."
    nvljohn "总有一天，我们会把这美梦变成现实。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10257
translate zh_Hans talay_mc_storyline_116_20204b1b:

    # nvltalay "Do you really believe that?"
    nvltalay "你真的相信，我们能做到吗？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10259
translate zh_Hans talay_mc_storyline_116_fc915972:

    # nvljohn "If we want it enough, yes."
    nvljohn "只要我们足够渴望，就一定能。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10261
translate zh_Hans talay_mc_storyline_116_6714e6dc:

    # nvltalay "I want to dream with you."
    nvltalay "我想和你一起，沉溺在这美梦中。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10263
translate zh_Hans talay_mc_storyline_116_032cdbe9:

    # nvljohn "Then let’s start dreaming together."
    nvljohn "那么，就让我们一起，放纵地做梦吧。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10265
translate zh_Hans talay_mc_storyline_116_c95ff955:

    # nvltalay "Okay, it’s a date. Future plans."
    nvltalay "好，就这么定了。这是我们未来的，最甜蜜的约定。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10267
translate zh_Hans talay_mc_storyline_116_efd375fa:

    # nvljohn "You make me believe anything’s possible."
    nvljohn "你让我相信，只要有你，一切禁忌都能打破，一切不可能都能实现。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10269
translate zh_Hans talay_mc_storyline_116_9775beae:

    # nvltalay "Me too. I needed this hope."
    nvltalay "我也是。我太需要这份，能让我为之疯狂的希望了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10271
translate zh_Hans talay_mc_storyline_116_8aa3aa1f:

    # nvljohn "One step at a time, love."
    nvljohn "亲爱的，一步一步来，我们不急。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10273
translate zh_Hans talay_mc_storyline_116_4eb5d9b8:

    # nvltalay "You’re right. We have each other already."
    nvltalay "你说得对。我们已经拥有彼此，这最珍贵的宝藏了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10275
translate zh_Hans talay_mc_storyline_116_9121f856:

    # nvljohn "The rest is just details."
    nvljohn "其他的一切，都不过是微不足道的细枝末节。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10277
translate zh_Hans talay_mc_storyline_116_bc7e5a57:

    # nvltalay "Now I can fall asleep with a smile."
    nvltalay "现在，我可以带着满足的微笑，沉沉睡去。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10279
translate zh_Hans talay_mc_storyline_116_e36f9716:

    # nvljohn "Sweet dreams, beach girl."
    nvljohn "甜美的梦乡，我的海滩尤物。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10295
translate zh_Hans talay_mc_storyline_116_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10315
translate zh_Hans talay_mc_storyline_117_ec6838ec:

    # nvl clear
    # nvlcecilia "Trying on outfits, I swear nothing fits me right!"
    nvl clear
    nvlcecilia "试穿这些衣服，我发誓没有一件能衬托出我的美！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10319
translate zh_Hans talay_mc_storyline_117_ef5a9e98:

    # nvltalay "You look gorgeous, stop being dramatic!"
    nvltalay "你美得惊人，别再凡尔赛了！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10321
translate zh_Hans talay_mc_storyline_117_4b9fa130:

    # nvlcecilia "Look who’s talking! This dress makes you look 10 years younger."
    nvlcecilia "看看是谁在说我！这条裙子让你看起来年轻了不止十岁，简直是回春了！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10323
translate zh_Hans talay_mc_storyline_117_35b64ce3:

    # nvltalay "You think so? I feel so… different in it."
    nvltalay "你真的觉得吗？我穿上它感觉……整个人都焕然一新了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10325
translate zh_Hans talay_mc_storyline_117_8852391e:

    # nvlcecilia "You’re glowing. It’s like old times, before all the stress."
    nvlcecilia "你容光焕发，简直是光彩照人。就像回到了以前，那些无忧无虑的日子。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10327
translate zh_Hans talay_mc_storyline_117_763f7669:

    # nvltalay "I used to love shopping. Forgot how fun it was."
    nvltalay "我以前超爱购物的。都忘了这种尽情挥霍的乐趣了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10329
translate zh_Hans talay_mc_storyline_117_84381f2f:

    # nvlcecilia "Mum, you deserve to feel pretty. To feel alive."
    nvlcecilia "妈妈，你值得拥有这份美丽，值得感受这份鲜活的生命力。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10331
translate zh_Hans talay_mc_storyline_117_604f2c3c:

    # nvltalay "With you, I do. Today I feel… wanted again."
    nvltalay "有你在身边，我才感受得到。今天我又一次感到……被渴望，被珍视。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10333
translate zh_Hans talay_mc_storyline_117_09671513:

    # nvlcecilia "Let’s get some crazy shoes to match."
    nvlcecilia "我们去挑双最狂野的鞋子来搭配，好不好？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10335
translate zh_Hans talay_mc_storyline_117_85b53023:

    # nvltalay "If I fall, it’ll be your fault!"
    nvltalay "如果我摔倒了，那可都是你这个小坏蛋的错！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10337
translate zh_Hans talay_mc_storyline_117_042c9998:

    # nvlcecilia "Deal. But at least you’ll fall looking amazing."
    nvlcecilia "成交！但就算摔倒，你也会是全场最惊艳的那个！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10339
translate zh_Hans talay_mc_storyline_117_664a8902:

    # nvltalay "Thank you for dragging me out today."
    nvltalay "谢谢你今天把我从家里“绑架”出来。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10341
translate zh_Hans talay_mc_storyline_117_1fde7dfa:

    # nvlcecilia "Always. We need more days like this."
    nvlcecilia "永远如此。我们需要更多这样，只属于我们的美好时光。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10343
translate zh_Hans talay_mc_storyline_117_28d88810:

    # nvltalay "Promise we’ll do it again?"
    nvltalay "答应我，我们还会再来一次，好吗？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10345
translate zh_Hans talay_mc_storyline_117_00ba92ba:

    # nvlcecilia "Promise. Maybe next time, spa day?"
    nvlcecilia "答应你！也许下次，我们可以去水疗中心，好好放松一下？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10347
translate zh_Hans talay_mc_storyline_117_f21d9506:

    # nvltalay "Perfect. My treat."
    nvltalay "太棒了！我请客，随便你挑！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10349
translate zh_Hans talay_mc_storyline_117_ddd9f8bb:

    # nvlcecilia "Yay! Let’s grab some ice cream too."
    nvlcecilia "耶！我们再去吃个冰淇淋，好不好？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10351
translate zh_Hans talay_mc_storyline_117_100a330d:

    # nvltalay "You read my mind."
    nvltalay "你真是太懂我的心了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10353
translate zh_Hans talay_mc_storyline_117_33258cb7:

    # nvlcecilia "Love you, beautiful."
    nvlcecilia "爱你，我的大美人。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10355
translate zh_Hans talay_mc_storyline_117_9acfff54:

    # nvltalay "Love you too, silly girl."
    nvltalay "我也爱你，我的小傻瓜。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10371
translate zh_Hans talay_mc_storyline_117_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10391
translate zh_Hans talay_mc_storyline_118_5c7f53ff:

    # nvl clear
    # nvlsalim "Where have you been? It’s almost midnight again."
    nvl clear
    nvlsalim "凯茜，你又死到哪里去了？都快半夜了！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10395
translate zh_Hans talay_mc_storyline_118_5bd9fe0d:

    # nvltalay "Out."
    nvltalay "出去了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10397
translate zh_Hans talay_mc_storyline_118_5495162a:

    # nvlsalim "Out? Doing what? Who with?"
    nvlsalim "出去了？干什么去了？又跟哪个野男人鬼混去了？！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10399
translate zh_Hans talay_mc_storyline_118_2d5fa4b0:

    # nvltalay "Does it matter?"
    nvltalay "这很重要吗？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10401
translate zh_Hans talay_mc_storyline_118_9a3d64c2:

    # nvlsalim "It does when my wife comes home late every night."
    nvlsalim "凯茜，你每晚都这么晚回家，你觉得这正常吗？！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10403
translate zh_Hans talay_mc_storyline_118_43739498:

    # nvltalay "I have my own life, Salim. You know that."
    nvltalay "萨利姆，我有我自己的生活，你他妈的知道的。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10405
translate zh_Hans talay_mc_storyline_118_305f1e49:

    # nvlsalim "Not like this. You never used to act this way."
    nvlsalim "才不是这样！你以前从来不会像个荡妇一样！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10407
translate zh_Hans talay_mc_storyline_118_3fcaadc7:

    # nvlsalim "Are you hiding something from me?"
    nvlsalim "你是不是在瞒着我什么？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10409
translate zh_Hans talay_mc_storyline_118_d86854f1:

    # nvltalay "I don’t owe you explanations."
    nvltalay "我没必要向你这个废物解释什么。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10411
translate zh_Hans talay_mc_storyline_118_06c20fe9:

    # nvlsalim "You think you can just do whatever you want?"
    nvlsalim "你以为你可以想怎么浪就怎么浪吗？！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10413
translate zh_Hans talay_mc_storyline_118_cfd553bb:

    # nvltalay "I think I’m tired of pretending."
    nvltalay "我想我他妈的已经厌倦了跟你装模作样！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10415
translate zh_Hans talay_mc_storyline_118_eae23e71:

    # nvlsalim "Unbelievable… You weren’t like this before."
    nvlsalim "简直难以置信……你以前可不是这种放荡的女人！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10417
translate zh_Hans talay_mc_storyline_118_4512b296:

    # nvltalay "No, I wasn’t. But I’m not the same woman you married."
    nvltalay "是，我不是。但我早他妈的不是你当初娶的那个蠢女人了！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10419
translate zh_Hans talay_mc_storyline_118_a0249716:

    # nvlsalim "You’re making a mistake."
    nvlsalim "你会后悔的，凯茜，你会犯下大错的！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10421
translate zh_Hans talay_mc_storyline_118_38972280:

    # nvltalay "Maybe. But it’s mine to make."
    nvltalay "也许吧。但这是我自己的选择，我的身体，我做主！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10423
translate zh_Hans talay_mc_storyline_118_f98a73a6:

    # nvlsalim "Fine. Don’t expect me to wait up for you."
    nvlsalim "好啊。那你就别指望我还会像条狗一样等你回来！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10425
translate zh_Hans talay_mc_storyline_118_9d5b592e:

    # nvltalay "Don’t bother."
    nvltalay "别自作多情了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10441
translate zh_Hans talay_mc_storyline_118_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10462
translate zh_Hans talay_mc_storyline_119_035fcba0:

    # nvl clear
    # nvltalay "I woke up and the first thing I saw was you."
    nvl clear
    nvltalay "我醒来，第一眼就看到了你，赤裸地躺在我身侧。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10466
translate zh_Hans talay_mc_storyline_119_68977222:

    # nvltalay "I never want to wake up alone again."
    nvltalay "我再也不想，没有你的温存，独自醒来了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10468
translate zh_Hans talay_mc_storyline_119_b463cd99:

    # nvljohn "I love mornings like this."
    nvljohn "我爱死这样被你填满的早晨了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10470
translate zh_Hans talay_mc_storyline_119_4f06e355:

    # nvljohn "Watching you sleep, tangled up with me."
    nvljohn "看着你沉睡，我们赤裸的身体紧密纠缠，汗液交织。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10472
translate zh_Hans talay_mc_storyline_119_379c076c:

    # nvltalay "It feels right, doesn’t it?"
    nvltalay "这种感觉，简直是天经地义，对吧？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10474
translate zh_Hans talay_mc_storyline_119_21181350:

    # nvljohn "Perfect. I could get used to this life."
    nvljohn "完美。我简直想一辈子都沉溺在这种被你肏翻的生活里。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10476
translate zh_Hans talay_mc_storyline_119_ca11d3a6:

    # nvltalay "Room service breakfast, messy hair, nothing to do but love."
    nvltalay "客房送餐的早餐，凌乱的秀发，除了尽情地爱，我们什么都不用做。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10478
translate zh_Hans talay_mc_storyline_119_de8d25ab:

    # nvljohn "You in my shirt, stealing my coffee."
    nvljohn "你穿着我的衬衫，偷喝我的咖啡，那画面简直要命。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10480
translate zh_Hans talay_mc_storyline_119_d471b5e2:

    # nvltalay "You making me laugh so early…"
    nvltalay "你这么早就把我逗得心痒难耐……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10482
translate zh_Hans talay_mc_storyline_119_3670d608:

    # nvljohn "Can we freeze time, just for today?"
    nvljohn "我们能否就此冻结时间，就今天一天，永远沉沦？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10484
translate zh_Hans talay_mc_storyline_119_a108ad32:

    # nvltalay "Let’s try. Let’s not rush, okay?"
    nvltalay "让我们试试吧。别急，慢慢来，好吗？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10486
translate zh_Hans talay_mc_storyline_119_ebab8c94:

    # nvljohn "No plans, no worries. Just us."
    nvljohn "没有计划，没有烦恼。只有我们俩，赤裸相对，尽情欢愉。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10488
translate zh_Hans talay_mc_storyline_119_4d8c5316:

    # nvltalay "You make the world disappear."
    nvltalay "你让我彻底忘记了世俗的一切，只剩下你。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10490
translate zh_Hans talay_mc_storyline_119_befa8240:

    # nvljohn "That’s my job. Make you happy."
    nvljohn "这就是我的使命。让你欲仙欲死，尽情欢愉。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10492
translate zh_Hans talay_mc_storyline_119_d32c7543:

    # nvltalay "Mission accomplished."
    nvltalay "任务完成。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10494
translate zh_Hans talay_mc_storyline_119_2f615f0e:

    # nvljohn "I’ll never get enough of you."
    nvljohn "我永远都无法满足于你，对你的渴望永无止境。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10496
translate zh_Hans talay_mc_storyline_119_76178f07:

    # nvltalay "I hope you never try."
    nvltalay "我希望你永远都不要停止对我的索取。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10498
translate zh_Hans talay_mc_storyline_119_e56442b6:

    # nvljohn "Let’s order another coffee."
    nvljohn "我们再点一杯咖啡，然后继续我们的缠绵。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10500
translate zh_Hans talay_mc_storyline_119_92ed0075:

    # nvljohn "Stay a little longer."
    nvljohn "再多待一会儿，好吗？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10502
translate zh_Hans talay_mc_storyline_119_66f5af16:

    # nvltalay "Deal. My perfect morning."
    nvltalay "成交。这简直是我最完美的，被你操弄的早晨。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10518
translate zh_Hans talay_mc_storyline_119_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10538
translate zh_Hans talay_mc_storyline_120_6f4201ce:

    # nvl clear
    # nvltalay "Do you ever feel like you work just to pay bills?"
    nvl clear
    nvltalay "你有没有觉得，我们工作，就是为了赚够钱，然后尽情挥霍？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10542
translate zh_Hans talay_mc_storyline_120_3ba65a84:

    # nvljohn "Every single day. My boss is a nightmare."
    nvljohn "每天都是这样。我的老板简直是个该死的噩梦。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10544
translate zh_Hans talay_mc_storyline_120_534cf5c6:

    # nvltalay "I had a crazy meeting today, but they might promote me."
    nvltalay "我今天开了一个超刺激的会，他们可能会提拔我。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10546
translate zh_Hans talay_mc_storyline_120_2375b5cb:

    # nvljohn "That’s amazing! You deserve it."
    nvljohn "太棒了！你这个小妖精，绝对值得拥有！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10548
translate zh_Hans talay_mc_storyline_120_c530e3d7:

    # nvltalay "Fingers crossed. If it happens, we’re celebrating."
    nvltalay "但愿如此。如果真成了，我们可要好好庆祝一番，彻夜狂欢！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10550
translate zh_Hans talay_mc_storyline_120_96ffc5eb:

    # nvljohn "Deal. Drinks on me."
    nvljohn "成交！今晚的酒，我请客，不醉不归！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10552
translate zh_Hans talay_mc_storyline_120_73577807:

    # nvltalay "What about you? Any good news?"
    nvltalay "你呢？有没有什么能让我兴奋的好消息？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10554
translate zh_Hans talay_mc_storyline_120_2b458162:

    # nvljohn "Actually, landed a new client."
    nvljohn "实际上，我成功勾搭上了一个大客户。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10556
translate zh_Hans talay_mc_storyline_120_8063159f:

    # nvltalay "Look at us, climbing up in the world."
    nvltalay "看看我们，正在这世俗的舞台上，一步步爬向巅峰。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10558
translate zh_Hans talay_mc_storyline_120_362f3d0f:

    # nvljohn "Teamwork makes the dream work."
    nvljohn "团队合作，才能让我们的欲望成真。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10560
translate zh_Hans talay_mc_storyline_120_ad779a66:

    # nvltalay "I wish we could work together every day."
    nvltalay "我真希望，我们能每天都黏在一起工作。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10562
translate zh_Hans talay_mc_storyline_120_fb85f94e:

    # nvljohn "Maybe one day."
    nvljohn "也许有一天吧。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10564
translate zh_Hans talay_mc_storyline_120_094d0fbe:

    # nvljohn "My new coworker, the prettiest in the world."
    nvljohn "我的新同事，这世上最勾魂摄魄的小妖精。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10566
translate zh_Hans talay_mc_storyline_120_4bb4507d:

    # nvltalay "You’d never get any work done with me there."
    nvltalay "有我在你身边，你恐怕连正事都顾不上了吧？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10568
translate zh_Hans talay_mc_storyline_120_a3ea3908:

    # nvljohn "Maybe that’s the point."
    nvljohn "也许……这才是我的真正目的。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10570
translate zh_Hans talay_mc_storyline_120_ae699893:

    # nvltalay "You’re impossible… but I love you for it."
    nvltalay "你这个磨人的小妖精……但我就是爱死你这副磨人的劲儿了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10572
translate zh_Hans talay_mc_storyline_120_d2e60115:

    # nvljohn "Love you too. Go get that promotion."
    nvljohn "爱你。去争取升职吧，宝贝。|爱你。去把那升职机会狠狠拿下，宝贝。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10574
translate zh_Hans talay_mc_storyline_120_6e5fb28e:

    # nvltalay "I’ll do my best!"
    nvltalay "我会拼尽全力的！|我会拼尽全力的！"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10590
translate zh_Hans talay_mc_storyline_120_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10609
translate zh_Hans talay_mc_storyline_121_b909236d:

    # nvl clear
    # nvltalay "I’ve been thinking a lot these past days."
    nvl clear
    nvltalay "这几天我一直在想很多事。|这几天我一直在想很多事，想得心痒痒的。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10613
translate zh_Hans talay_mc_storyline_121_5bd9817e:

    # nvltalay "About my life… and what I want."
    nvltalay "关于我的生活……以及我真正想要什么。|关于我的生活……以及我这具身体到底渴望什么。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10615
translate zh_Hans talay_mc_storyline_121_77a9f197:

    # nvlcecilia "Of course. You can tell me anything."
    nvlcecilia "当然。你什么都可以告诉我。|当然。你什么都可以对我敞开。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10617
translate zh_Hans talay_mc_storyline_121_15420588:

    # nvltalay "I had another fight with your father."
    nvltalay "我又跟你爸吵了一架。|我又跟你爸那老东西吵了一架。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10619
translate zh_Hans talay_mc_storyline_121_34eafb3e:

    # nvltalay "This time felt different."
    nvltalay "这次的感觉很不一样。|这次的感觉，简直是天翻地覆。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10621
translate zh_Hans talay_mc_storyline_121_b6ed60bb:

    # nvlcecilia "Different how?"
    nvlcecilia "怎么个不一样法？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10623
translate zh_Hans talay_mc_storyline_121_e77e4c92:

    # nvltalay "I didn’t feel scared."
    nvltalay "我一点都不觉得害怕。|我一点都不觉得害怕。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10625
translate zh_Hans talay_mc_storyline_121_a8697468:

    # nvltalay "I didn’t apologise."
    nvltalay "我没有道歉。|我没有道歉。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10627
translate zh_Hans talay_mc_storyline_121_642a2685:

    # nvltalay "I didn’t even feel guilty."
    nvltalay "我甚至没有感到内疚。|我甚至连一丝内疚都没有。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10629
translate zh_Hans talay_mc_storyline_121_74a62fcd:

    # nvlcecilia "That sounds… big."
    nvlcecilia "听起来……真是个大动作。|听起来……真是个大动作。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10631
translate zh_Hans talay_mc_storyline_121_a1a2daff:

    # nvltalay "It is."
    nvltalay "就是这样。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10633
translate zh_Hans talay_mc_storyline_121_95da6f9f:

    # nvltalay "For the first time, I thought maybe I don’t want this marriage anymore."
    nvltalay "我第一次觉得，也许我根本不想要这段婚姻了。|我第一次觉得，也许我根本不想要这段该死的婚姻了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10635
translate zh_Hans talay_mc_storyline_121_afed9bd9:

    # nvltalay "Maybe I finally have the courage."
    nvltalay "或许我终于鼓起了勇气。|或许我终于鼓起了那股子劲儿。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10637
translate zh_Hans talay_mc_storyline_121_59cc0cc0:

    # nvlcecilia "Mum… that’s huge."
    nvlcecilia "妈……那可真是个惊天动地的大事。|妈……那可真是个惊天动地的大事。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10639
translate zh_Hans talay_mc_storyline_121_3b3fb160:

    # nvltalay "I’m not saying I’ll do it tomorrow."
    nvltalay "我不是说我明天就会去做。|我不是说我明天就会去干。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10641
translate zh_Hans talay_mc_storyline_121_9b8eeca6:

    # nvltalay "But the thought doesn’t terrify me anymore."
    nvltalay "但现在这种想法不再让我感到恐惧了。|但现在这种想法，再也吓不住我了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10643
translate zh_Hans talay_mc_storyline_121_7634a475:

    # nvlcecilia "You deserve to be happy. Truly happy."
    nvlcecilia "你值得拥有幸福。真正的幸福。|你值得拥有幸福。真正的、能让你浑身舒畅的幸福。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10645
translate zh_Hans talay_mc_storyline_121_7b43225f:

    # nvltalay "Hearing that from you means everything."
    nvltalay "听到你这么说，对我来说意义非凡。|听到你这么说，对我来说，简直是天大的慰藉。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10647
translate zh_Hans talay_mc_storyline_121_6577cc8c:

    # nvltalay "I don’t want to live another year feeling invisible."
    nvltalay "我不想再过一年感觉自己像个隐形人一样。|我不想再过一年，感觉自己像个透明的死人一样。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10649
translate zh_Hans talay_mc_storyline_121_a7608c5d:

    # nvlcecilia "Whatever you decide, I’m with you."
    nvlcecilia "无论你做什么决定，我都支持你。|无论你做什么决定，我都挺你到底。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10651
translate zh_Hans talay_mc_storyline_121_7dfe6a26:

    # nvltalay "Thank you, my girl."
    nvltalay "谢谢你，我的乖女儿。|谢谢你，我的乖女儿。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10653
translate zh_Hans talay_mc_storyline_121_c84aac42:

    # nvltalay "I needed to say this out loud."
    nvltalay "我需要把这些话说出来。|我需要把这些话痛痛快快地说出来。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10655
translate zh_Hans talay_mc_storyline_121_773bf703:

    # nvlcecilia "Anytime. Always."
    nvlcecilia "随时。永远。|随时。永远。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10657
translate zh_Hans talay_mc_storyline_121_7368b483:

    # nvltalay "I feel lighter already."
    nvltalay "我感觉轻松多了。|我感觉整个人都轻飘飘的了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10673
translate zh_Hans talay_mc_storyline_121_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10693
translate zh_Hans talay_mc_storyline_122_65456f90:

    # nvl clear
    # nvltalay "I need to tell you something important."
    nvl clear
    nvltalay "我需要告诉你一件重要的事情。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10697
translate zh_Hans talay_mc_storyline_122_0bcf9923:

    # nvltalay "I had a bad fight with Salim."
    nvltalay "我和萨利姆大吵了一架。|我和萨利姆那混蛋大吵了一架。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10699
translate zh_Hans talay_mc_storyline_122_354b38c2:

    # nvltalay "Not shouting… just cold words."
    nvltalay "没有大声争吵……只是冷冰冰的话语。|没有大声争吵……只是冷冰冰的，像刀子一样的话语。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10701
translate zh_Hans talay_mc_storyline_122_81c15e34:

    # nvljohn "That’s usually worse."
    nvljohn "通常情况下，那更糟糕。|通常情况下，那更他妈的糟糕。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10703
translate zh_Hans talay_mc_storyline_122_65994dba:

    # nvltalay "I didn’t back down."
    nvltalay "我没有退缩。|我没有退缩。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10705
translate zh_Hans talay_mc_storyline_122_f8bae714:

    # nvltalay "I didn’t explain myself."
    nvltalay "我没有解释自己。|我没有解释自己。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10707
translate zh_Hans talay_mc_storyline_122_cf58780c:

    # nvltalay "And I realised something."
    nvltalay "我意识到了一件事。|我意识到了一件事。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10709
translate zh_Hans talay_mc_storyline_122_ef9365ea:

    # nvljohn "Tell me."
    nvljohn "告诉我。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10711
translate zh_Hans talay_mc_storyline_122_4c488c83:

    # nvltalay "I’m tired of him."
    nvltalay "我受够他了。|我受够他了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10713
translate zh_Hans talay_mc_storyline_122_89cede78:

    # nvltalay "Of the control. Of the distance."
    nvltalay "受够了他的控制。受够了这种距离感。|受够了他的控制。受够了这种他妈的距离感。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10715
translate zh_Hans talay_mc_storyline_122_0f1a8999:

    # nvltalay "I even talked to my daughter about separating."
    nvltalay "我甚至和女儿谈过分居的事。|我甚至和女儿谈过分居的事。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10717
translate zh_Hans talay_mc_storyline_122_d67cf4fc:

    # nvljohn "That must have taken a lot of courage."
    nvljohn "那一定需要很大的勇气。|那一定需要很大的勇气。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10719
translate zh_Hans talay_mc_storyline_122_f581fbd8:

    # nvltalay "It did."
    nvltalay "确实如此。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10721
translate zh_Hans talay_mc_storyline_122_c9d662c2:

    # nvltalay "But it felt right."
    nvltalay "但感觉是对的。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10723
translate zh_Hans talay_mc_storyline_122_17ac9db5:

    # nvltalay "For the first time in years."
    nvltalay "多年来第一次。|多年来第一次。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10725
translate zh_Hans talay_mc_storyline_122_d3aaf30c:

    # nvljohn "Whatever you decide, I’ll respect it."
    nvljohn "无论你做什么决定，我都会尊重。|无论你做什么决定，我都会尊重。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10727
translate zh_Hans talay_mc_storyline_122_d3424114:

    # nvljohn "I’m proud of you."
    nvljohn "我为你感到骄傲。|我为你感到骄傲。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10729
translate zh_Hans talay_mc_storyline_122_a1741800:

    # nvltalay "You make me feel strong."
    nvltalay "你让我感觉自己很强大。|你让我感觉自己强大得能把天捅个窟窿。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10731
translate zh_Hans talay_mc_storyline_122_04a5541b:

    # nvltalay "Like I’m allowed to want more."
    nvltalay "好像我还有权利想要更多。|好像我还有权利，去渴望更多、更刺激的。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10733
translate zh_Hans talay_mc_storyline_122_761ebd02:

    # nvljohn "You are."
    nvljohn "你是。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10735
translate zh_Hans talay_mc_storyline_122_2465f6af:

    # nvltalay "I don’t know when…"
    nvltalay "我不知道什么时候……|我不知道什么时候……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10737
translate zh_Hans talay_mc_storyline_122_602b7a2c:

    # nvltalay "But I think I’m finally done with him."
    nvltalay "但我认为我终于和他彻底结束了。|但我认为我终于和他彻底玩完了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10739
translate zh_Hans talay_mc_storyline_122_dd2eb8ae:

    # nvljohn "Take your time. I’m here."
    nvljohn "别着急。我在这儿。|别着急。我在这儿，等你。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10741
translate zh_Hans talay_mc_storyline_122_5af99164:

    # nvltalay "That’s all I needed to hear."
    nvltalay "我只需要听到这些就够了。|我只需要听到这些就够了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10757
translate zh_Hans talay_mc_storyline_122_53c71d7c:

    # nvl_narrator "\nEnd of the conversation...\n"
    nvl_narrator "\\nEnd of the conversation...\\n|对话结束……"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10777
translate zh_Hans talay_mc_storyline_123_a9fb3641:

    # nvl clear
    # nvltalay "Salim is leaving for a work trip."
    nvl clear
    nvltalay "萨利姆要出差了。|萨利姆那家伙要出差了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10781
translate zh_Hans talay_mc_storyline_123_f75bfce5:

    # nvltalay "He’ll be gone for a few days."
    nvltalay "他将离开几天。|他将离开几天。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10783
translate zh_Hans talay_mc_storyline_123_51cda073:

    # nvljohn "How do you feel about that?"
    nvljohn "你们觉得怎么样？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10785
translate zh_Hans talay_mc_storyline_123_4709e6b5:

    # nvltalay "Relieved."
    nvltalay "松了口气。|松了口气，浑身都酥了。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10787
translate zh_Hans talay_mc_storyline_123_099a1b7c:

    # nvltalay "And a little excited."
    nvltalay "还有点兴奋。|还有点，该死的兴奋。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10789
translate zh_Hans talay_mc_storyline_123_b966b8a4:

    # nvljohn "That sounds dangerous."
    nvljohn "听起来很危险。|听起来很危险，很刺激。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10791
translate zh_Hans talay_mc_storyline_123_b342fc64:

    # nvltalay "Maybe."
    nvltalay "或许吧。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10793
translate zh_Hans talay_mc_storyline_123_5d7f7cf3:

    # nvltalay "Would you like to stay with me?"
    nvltalay "你愿意留下来陪我吗？|你愿意留下来，好好陪陪我吗？"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10795
translate zh_Hans talay_mc_storyline_123_d653fd3f:

    # nvltalay "Just for these days."
    nvltalay "仅限这几天。|就这几天，只属于我们的几天。"

# game/scripts/dialogues/talay/talay_mc_storyline.rpy:10797
translate zh_Hans talay_mc_storyline_123_a98198c3:

